{
  "version": 2,
  "regions": ["fra1"],
  "outputDirectory": "frontend",
  "rewrites": [
    { "source": "/auth/(.*)",                 "destination": "/api/index" },
    { "source": "/api/user/(.*)",             "destination": "/api/index" },
    { "source": "/api/conversations/(.*)",    "destination": "/api/index" },
    { "source": "/api/userdata/(.*)",         "destination": "/api/index" },
    { "source": "/api/user",                  "destination": "/api/index" },
    { "source": "/api/conversations",         "destination": "/api/index" },
    { "source": "/api/userdata",              "destination": "/api/index" },
    { "source": "/health",                    "destination": "/api/index" },
    { "source": "/app",                       "destination": "/app.html" },
    { "source": "/",                          "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
