# Force LF line endings on files exécutés sur le VPS Linux,
# même si on commit depuis Windows (sinon bash refuse les CRLF).
*.sh         text eol=lf
Dockerfile   text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.conf       text eol=lf
.env.example text eol=lf

# Binaires : pas de conversion
*.png        binary
*.jpg        binary
*.ico        binary
*.docx       binary
