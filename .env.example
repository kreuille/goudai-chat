# =====================================================================
#  GoudAI Chat — Variables d'environnement
#  Copie ce fichier en `.env` (dev local) ou ajoute ces variables dans
#  Vercel Dashboard > Settings > Environment Variables (production).
#  ⚠️  Le fichier .env ne doit JAMAIS être committé.
# =====================================================================

# ── Serveur (dev local uniquement, Vercel ignore PORT) ────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://goudai.vercel.app

# ── JWT ───────────────────────────────────────────────────────────
# Génère avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=30d

# ── Chiffrement des clés API (AES-256-GCM) ────────────────────────
# Génère avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Google OAuth2 (« Se connecter avec Google ») ─────────────────
# Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI : https://goudai.vercel.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://goudai.vercel.app/auth/google/callback

# ── Google Service Account (Sheets + Drive côté serveur) ─────────
# DEUX modes au choix :
#
# A. PRODUCTION VERCEL (recommandé) : base64 du JSON service-account
#    Génération sur ton PC :
#      [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
#    Puis copie cette string dans Vercel Dashboard Env Vars.
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# B. DEV LOCAL : chemin vers le fichier sur disque (utilisé si JSON_B64 vide)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./data/goudai-secrets/service-account.json

# ── Google Sheets (DB utilisateurs) ──────────────────────────────
# ID dans l'URL : /spreadsheets/d/<ID>/edit
# Partager le Sheet en éditeur avec l'email du service account.
GOOGLE_SHEET_ID=

# ── Upstash Redis (stockage des conversations) ───────────────────
# Créer une DB sur https://console.upstash.com/redis → région Frankfurt
# Onglet "REST API" → copier les 2 valeurs ci-dessous :
UPSTASH_REDIS_REST_URL=https://eu1-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# ── (Obsolete sur Vercel) Stockage local des conversations ───────
# Conservé pour fallback dev local sans Upstash.
# CONV_STORAGE_PATH=./data/conversations
