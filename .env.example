# =====================================================================
#  GoudAI Chat — Variables d'environnement
#  Copie ce fichier en `.env` et remplis les valeurs réelles.
#  ⚠️  Le fichier .env ne doit JAMAIS être committé.
# =====================================================================

# ── Serveur ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://goudai.tondomaine.fr

# ── JWT ───────────────────────────────────────────────────────────
# Génère avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=30d

# ── Chiffrement des clés API (AES-256-GCM) ────────────────────────
# Génère avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ── Google OAuth2 (« Se connecter avec Google ») ─────────────────
# Console GCP → APIs & Services → Credentials
# Authorized redirect URI : https://goudai.tondomaine.fr/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://goudai.tondomaine.fr/auth/google/callback

# ── Google Service Account (Sheets + Drive côté serveur) ─────────
# Le fichier JSON est monté dans le container via docker-compose
# (./data/goudai-secrets:/etc/goudai:ro), il NE figure pas dans Git.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/etc/goudai/service-account.json

# ── Google Sheets (DB utilisateurs) ──────────────────────────────
# ID dans l'URL : /spreadsheets/d/<ID>/edit
# Partager le Sheet en éditeur avec l'email du service account.
GOOGLE_SHEET_ID=

# ── Google Drive (stockage JSON par utilisateur) ─────────────────
# ID du dossier racine (URL : /drive/folders/<ID>)
# Partager le dossier en éditeur avec l'email du service account.
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── Stockage local des conversations ─────────────────────────────
# Doit correspondre au volume monté dans docker-compose.yml
# (./data/conversations:/app/data/conversations).
CONV_STORAGE_PATH=/app/data/conversations
