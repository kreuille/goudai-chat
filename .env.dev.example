# =====================================================================
#  GoudAI Chat — .env.dev (environnement isolé sur dev.goudai.guedou.com)
#
#  Copie ce fichier en `.env` dans /root/goudai-chat-dev/ sur le VPS,
#  puis ajuste UNIQUEMENT les valeurs marquées ⚠️ DEV.
#  Tout le reste (JWT_SECRET, ENCRYPTION_KEY, GOOGLE_CLIENT_*) doit
#  être strictement identique à .env de la prod (compat cookies + OAuth).
# =====================================================================

# ── Container & port (lus par docker-compose.yml) ────────────────
# ⚠️ DEV : noms et port dédiés pour ne pas entrer en collision avec la prod.
CONTAINER_NAME=goudai-app-dev
HOST_PORT=3002

# ── Serveur ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
# ⚠️ DEV : URL publique du sous-domaine dev (utilisée pour CORS et auth)
FRONTEND_URL=https://dev.goudai.guedou.com

# ── JWT ───────────────────────────────────────────────────────────
# ⚠️ Identique à la prod (sinon les cookies prod ne sont pas valides en dev)
JWT_SECRET=
JWT_EXPIRES_IN=30d

# ── Chiffrement (identique à la prod) ─────────────────────────────
ENCRYPTION_KEY=

# ── Google OAuth2 ────────────────────────────────────────────────
# ⚠️ Identiques à la prod (le même OAuth Client a 2 redirect URIs autorisées)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# ⚠️ DEV : redirect URI du sous-domaine dev — doit avoir été ajoutée dans la console Google Cloud
GOOGLE_REDIRECT_URI=https://dev.goudai.guedou.com/auth/google/callback

# ── Service Account (chemin dans le container, identique à la prod) ─
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/etc/goudai/service-account.json

# ── Google Sheets (DB users) ─────────────────────────────────────
# ⚠️ DEV : ID d'une 2e Sheet créée pour isoler les utilisateurs dev de la prod.
# Créer une nouvelle Google Sheet, ajouter un onglet "Users" avec les colonnes
# A→K (voir CLAUDE.md), partager avec l'email du service account en éditeur.
GOOGLE_SHEET_ID=

# ── Google Drive root (chemin filesystem local — voir CLAUDE.md, mal nommé) ─
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── Stockage local des conversations dev ─────────────────────────
# Chemin INTERNE au container (le mount externe est ./data/conversations
# du dossier /root/goudai-chat-dev, donc séparé physiquement de la prod).
CONV_STORAGE_PATH=/app/data/conversations
