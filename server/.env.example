# ── Serveur ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://goudai.tondomaine.fr

# ── JWT ───────────────────────────────────────────────────────────
# Génère avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET
JWT_EXPIRES_IN=30d

# ── Chiffrement des clés API (AES-256-GCM) ────────────────────────
# Génère avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX

# ── Google OAuth2 (pour connexion "Se connecter avec Google") ─────
# Créer sur https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URIs: https://goudai.tondomaine.fr/auth/google/callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=https://goudai.tondomaine.fr/auth/google/callback

# ── Google Service Account (pour Sheets + Drive) ─────────────────
# Créer sur https://console.cloud.google.com → IAM → Service Accounts
# Télécharger le JSON, mettre le chemin ici
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/etc/goudai/service-account.json

# ── Google Sheets ─────────────────────────────────────────────────
# ID du Google Sheet (dans l'URL: /spreadsheets/d/ID/edit)
# Partager le Sheet avec l'email du service account (editor)
GOOGLE_SHEET_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Drive ──────────────────────────────────────────────────
# ID du dossier racine "GoudAI-Users" sur Drive du service account
# Créer un dossier sur Drive, partager avec le service account, copier l'ID de l'URL
GOOGLE_DRIVE_ROOT_FOLDER_ID=1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
